{
  "manifest_version": 3,
  "name": "Cookie Manager",
  "version": "1.0",
  "permissions": ["cookies", "storage", "tabs", "browsingData"],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "action": { 
    "default_popup": "popup.html" 
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { 
    "service_worker": "background.js" 
  }
}